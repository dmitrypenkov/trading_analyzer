{
    "price_data_path": "data/ETHUSDT_1m.csv",
    "news_data_path": "data/news_calendar.csv",

    "settings": {
        "block_start": "00:00",
        "block_end": "13:00",
        "session_start": "13:00",
        "session_end": "20:00",
        "use_return_mode": false,
        "limit_only_entry": true,
        "from_previous_day": false,
        "trading_days": [0, 1, 2, 3, 4],
        "tp_multiplier": 1.0,
        "sl_multiplier": 1.0,
        "tp_coefficient": 0.9,
        "sl_slippage_coefficient": 1.02,
        "commission_rate": 0.0005,
        "min_range_size": 10,
        "max_range_size": 200,
        "use_fixed_tp_sl": false,
        "threshold_min": 0,
        "threshold_max": 999999,
        "fixed_tp_distance": 0,
        "fixed_sl_distance": 0,
        "use_news_filter": false,
        "news_impact_filter": [],
        "news_buffer_minutes": 0,
        "news_currency_filter": [],
        "skip_red_news_days": false,
        "start_date": "2024-01-01",
        "end_date": "2025-12-31"
    },

    "optimization": {
        "tp_range": [0.5, 3.0, 0.1],
        "sl_range": [0.3, 2.0, 0.1],
        "target": "max_r_dd_ratio",

        "use_time_optimization": true,
        "block_start_fixed": "00:00",
        "session_end_fixed": "20:00",
        "split_hour_min": 3,
        "split_hour_max": 18,
        "split_hour_step": 1,
        "from_previous_day": false,

        "export_top_n_csv": 10,
        "export_all_csv": false
    },

    "use_parallel": false,
    "output_dir": null
}
